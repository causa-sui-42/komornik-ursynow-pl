---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const licytacje = await getCollection('licytacje');
  return licytacje.map((licytacja) => ({
    params: { slug: licytacja.slug },
    props: { licytacja },
  }));
}) satisfies GetStaticPaths;

const { licytacja } = Astro.props;
const { Content } = await licytacja.render();
---

<BaseLayout 
  title={`${licytacja.data.title} - Licytacja`}
  description={licytacja.data.description}
>
  <div class="bg-gray-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <a href={`${base}licytacje`} class="inline-flex items-center text-primary-600 hover:text-primary-700 mb-6">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Powrót do listy licytacji
      </a>

      <article class="bg-white rounded-lg shadow-lg overflow-hidden">
        <div class="p-8">
          <div class="flex items-center justify-between mb-4">
            <span class="inline-block px-4 py-2 text-sm font-semibold text-primary-700 bg-primary-100 rounded-full">
              {licytacja.data.category.toUpperCase()}
            </span>
            <span class={`px-4 py-2 rounded-full text-sm font-semibold ${
              licytacja.data.status === 'aktywna' ? 'bg-green-100 text-green-800' :
              licytacja.data.status === 'zakonczona' ? 'bg-gray-100 text-gray-800' :
              'bg-red-100 text-red-800'
            }`}>
              {licytacja.data.status.toUpperCase()}
            </span>
          </div>

          <h1 class="text-4xl font-bold mb-4 text-gray-900">{licytacja.data.title}</h1>
          
          <div class="flex flex-wrap gap-6 mb-8 text-gray-600">
            <div class="flex items-center">
              <svg class="w-5 h-5 mr-2 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
              </svg>
              {licytacja.data.date.toLocaleDateString('pl-PL', { 
                weekday: 'long', 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
              })}
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 mr-2 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
              {licytacja.data.location}
            </div>
          </div>

          {licytacja.data.images && licytacja.data.images.length > 0 && (
            <div class="mb-8 grid grid-cols-1 md:grid-cols-2 gap-4">
              {licytacja.data.images.map((image: string) => (
                <img 
                  src={image} 
                  alt={licytacja.data.title}
                  class="w-full h-64 object-cover rounded-lg"
                />
              ))}
            </div>
          )}

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8 bg-gray-50 p-6 rounded-lg">
            {licytacja.data.startPrice && (
              <div>
                <h3 class="text-sm font-medium text-gray-500 mb-1">Cena wywoławcza</h3>
                <p class="text-2xl font-bold text-primary-600">{licytacja.data.startPrice}</p>
              </div>
            )}
            {licytacja.data.estimatedValue && (
              <div>
                <h3 class="text-sm font-medium text-gray-500 mb-1">Wartość szacunkowa</h3>
                <p class="text-2xl font-bold text-gray-900">{licytacja.data.estimatedValue}</p>
              </div>
            )}
          </div>

          <div class="prose prose-lg max-w-none mb-8">
            <h2 class="text-2xl font-bold mb-4 text-gray-900">Opis</h2>
            <p class="text-gray-700 leading-relaxed">{licytacja.data.description}</p>
            <Content />
          </div>

          <div class="border-t border-gray-200 pt-6">
            <h3 class="text-lg font-semibold mb-4 text-gray-900">Informacje dodatkowe</h3>
            <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-4">
              <p class="text-sm text-yellow-700">
                <strong>Ważne:</strong> Szczegółowe informacje dotyczące licytacji, warunków uczestnictwa 
                oraz wymaganych dokumentów dostępne są w kancelarii komorniczej. Prosimy o kontakt telefoniczny 
                lub osobisty w celu uzyskania pełnych informacji.
              </p>
            </div>
            <p class="text-sm text-gray-600">
              Data publikacji: {licytacja.data.publishDate.toLocaleDateString('pl-PL')}
            </p>
          </div>
        </div>
      </article>
    </div>
  </div>
</BaseLayout>
