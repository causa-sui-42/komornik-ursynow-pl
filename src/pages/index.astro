        </svg>
        <span class="text-xs font-medium tracking-widest uppercase">Warszawa</span>
        <span class="w-px h-4 bg-primary-300"></span>
        <span class="text-xs font-medium tracking-widest uppercase">Mokotów</span>
        <span class="w-px h-4 bg-primary-300"></span>
        <span class="text-xs font-medium tracking-widest uppercase">Ursynów</span>
        <!-- Scales mini icon -->
