            <p class="text-sm text-gray-600">Tel: 22 851 68 96</p>
            <p class="text-sm text-gray-600">warszawa13@komornik.pl</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wierzyciel / Dluznik Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
