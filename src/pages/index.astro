---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const aktualnosci = (await getCollection('aktualnosci'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const licytacje = (await getCollection('licytacje'))
  .filter(l => l.data.status === 'aktywna')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Kancelaria Komornicza Małgorzata Groszek - Kuszyk">
  <!-- Hero Section -->
  <section class="relative bg-primary-950 text-white overflow-hidden">
    <!-- Background pattern -->
