              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Adres</h3>
            <p class="text-sm text-gray-600">Al. KEN 55/2, 02-797 Warszawa</p>
            <p class="text-xs text-primary-600 mt-1">Ursynów &middot; stacja metra Imielin</p>
