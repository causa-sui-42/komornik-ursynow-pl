      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Wierzyciel Card -->
        <a href="/wierzyciel" class="group relative bg-gradient-to-br from-primary-900 to-primary-800 rounded-2xl p-8 text-white overflow-hidden hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
          <div class="absolute top-0 right-0 opacity-10">
            <svg class="w-40 h-40" viewBox="0 0 100 100" fill="none" stroke="white" stroke-width="1">
              <path d="M50 10v80M50 10l-20 20M50 10l20 20M20 50l10-20 10 20M60 50l10-20 10 20M20 50h20M60 50h20"/>
