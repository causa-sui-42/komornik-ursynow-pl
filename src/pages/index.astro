          <rect x="145" y="440" width="5" height="6" fill-opacity="0.2"/>
          <rect x="155" y="440" width="5" height="6" fill-opacity="0.2"/>
          <rect x="165" y="440" width="5" height="6" fill-opacity="0.2"/>
          <rect x="145" y="455" width="5" height="6" fill-opacity="0.2"/>
          <rect x="155" y="455" width="5" height="6" fill-opacity="0.2"/>
          <rect x="165" y="455" width="5" height="6" fill-opacity="0.2"/>

          <rect x="180" y="410" width="30" height="90"/>
          <rect x="185" y="420" width="5" height="6" fill-opacity="0.2"/>
          <rect x="195" y="420" width="5" height="6" fill-opacity="0.2"/>
          <rect x="185" y="435" width="5" height="6" fill-opacity="0.2"/>
