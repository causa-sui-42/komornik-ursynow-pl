          <rect x="259" y="400" width="6" height="8" fill-opacity="0.2"/>
          <rect x="235" y="420" width="6" height="8" fill-opacity="0.2"/>
          <rect x="247" y="420" width="6" height="8" fill-opacity="0.2"/>
          <rect x="259" y="420" width="6" height="8" fill-opacity="0.2"/>

          <!-- Building cluster left -->
