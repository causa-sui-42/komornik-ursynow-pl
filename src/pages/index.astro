          <path d="M20 5c-2 3-3 6-3 10 0 3 1 5 3 7"/>
          <path d="M20 22c2-2 5-4 8-3"/>
          <path d="M20 22c-1 3-1 7 2 10"/>
          <path d="M22 32c2 1 5 2 8 1"/>
          <path d="M17 12l-4-2m0 0l-1 3"/>
