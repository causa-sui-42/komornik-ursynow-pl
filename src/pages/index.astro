          <rect x="280" y="430" width="5" height="6" fill-opacity="0.2"/>
          <rect x="290" y="430" width="5" height="6" fill-opacity="0.2"/>
          <rect x="300" y="430" width="5" height="6" fill-opacity="0.2"/>
          <rect x="280" y="445" width="5" height="6" fill-opacity="0.2"/>
          <rect x="290" y="445" width="5" height="6" fill-opacity="0.2"/>
          <rect x="300" y="445" width="5" height="6" fill-opacity="0.2"/>

