---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
import { getCollection } from 'astro:content';

const allLicytacje = await getCollection('licytacje');
const aktywneLicytacje = allLicytacje
  .filter(l => l.data.status === 'aktywna')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout 
  title="Aktualne licytacje - Kancelaria Komornicza"
  description="Aktualne licytacje nieruchomości, pojazdów i ruchomości prowadzone przez Kancelarię Komorniczą"
>
  <div class="bg-gray-50 min-h-screen">
    <div class="relative bg-primary-950 text-white overflow-hidden">
      <div class="absolute inset-0 opacity-5">
        <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="licytacje-pattern" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
              <path d="M30 5v50M30 5l-10 10M30 5l10 10M15 25l5-10 5 10M35 25l5-10 5 10M15 25h10M35 25h10" stroke="white" stroke-width="0.5" fill="none"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#licytacje-pattern)"/>
        </svg>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="flex items-center space-x-2 text-accent-400 text-sm mb-4">
          <a href={base} class="hover:text-accent-300">Strona główna</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-primary-300">Licytacje</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Aktualne licytacje</h1>
        <p class="text-xl text-primary-300">
          Zapoznaj się z aktualną ofertą licytowanych nieruchomości i ruchomości
        </p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Filters -->
      <div class="mb-8 bg-white p-6 rounded-lg shadow-sm">
        <h2 class="text-lg font-semibold mb-4 text-gray-900">Filtruj licytacje</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Kategoria</label>
            <select id="category-filter" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500">
              <option value="">Wszystkie kategorię</option>
              <option value="nieruchomosci">Nieruchomości</option>
              <option value="ruchomosci">Ruchomości</option>
              <option value="pojazdy">Pojazdy</option>
              <option value="inne">Inne</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Sortowanie</label>
            <select id="sort-filter" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500">
              <option value="date-desc">Data (od najnowszych)</option>
              <option value="date-asc">Data (od najstarszych)</option>
              <option value="title-asc">Tytuł (A-Z)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Wyszukiwanie</label>
            <input 
              type="text" 
              id="search-input" 
              placeholder="Szukaj..."
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500"
            />
          </div>
        </div>
      </div>

      {aktywneLicytacje.length === 0 ? (
        <div class="bg-white rounded-lg shadow-sm p-12 text-center">
          <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
          </svg>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Brak aktywnych licytacji</h3>
          <p class="text-gray-600">Aktualnie nie ma zaplanowanych licytacji. Sprawdź ponownie później.</p>
        </div>
      ) : (
        <div id="auctions-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {aktywneLicytacje.map((licytacja) => (
            <div class="auction-card bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition" 
                 data-category={licytacja.data.category}
                 data-title={licytacja.data.title.toLowerCase()}
                 data-date={licytacja.data.date.valueOf()}>
              {licytacja.data.images && licytacja.data.images.length > 0 && (
                <div class="h-48 bg-gray-200 overflow-hidden">
                  <img 
                    src={licytacja.data.images[0]} 
                    alt={licytacja.data.title}
                    class="w-full h-full object-cover"
                  />
                </div>
              )}
              <div class="p-6">
                <div class="flex items-center justify-between mb-3">
                  <span class="inline-block px-3 py-1 text-xs font-semibold text-primary-700 bg-primary-100 rounded-full">
                    {licytacja.data.category.toUpperCase()}
                  </span>
                  <span class="text-xs text-gray-500">
                    {licytacja.data.date.toLocaleDateString('pl-PL')}
                  </span>
                </div>
                <h3 class="text-xl font-bold mb-2 text-gray-900">{licytacja.data.title}</h3>
                <p class="text-gray-600 mb-4 line-clamp-3">{licytacja.data.description}</p>
                
                <div class="space-y-2 mb-4 text-sm text-gray-700">
                  <p class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                    </svg>
                    {licytacja.data.location}
                  </p>
                  {licytacja.data.startPrice && (
                    <p class="flex items-center font-semibold text-primary-600">
                      <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                      </svg>
                      Cena wywoławcza: {licytacja.data.startPrice}
                    </p>
                  )}
                </div>
                
                <a 
                  href={`/licytacje/${licytacja.slug}`}
                  class="inline-block w-full text-center bg-primary-600 text-white py-2 px-4 rounded-lg font-semibold hover:bg-primary-700 transition"
                >
                  Zobacz szczegóły
                </a>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>

  <script>
    const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;
    const sortFilter = document.getElementById('sort-filter') as HTMLSelectElement;
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const auctionsGrid = document.getElementById('auctions-grid');
    const cards = Array.from(document.querySelectorAll('.auction-card')) as HTMLElement[];

    function filterAndSort() {
      const category = categoryFilter.value;
      const searchTerm = searchInput.value.toLowerCase();
      const sortBy = sortFilter.value;

      let visibleCards = cards.filter(card => {
        const cardCategory = card.dataset.category || '';
        const cardTitle = card.dataset.title || '';
        
        const matchesCategory = !category || cardCategory === category;
        const matchesSearch = !searchTerm || cardTitle.includes(searchTerm);
        
        return matchesCategory && matchesSearch;
      });

      // Sort
      visibleCards.sort((a, b) => {
        if (sortBy === 'date-desc') {
          return (Number(b.dataset.date) || 0) - (Number(a.dataset.date) || 0);
        } else if (sortBy === 'date-asc') {
          return (Number(a.dataset.date) || 0) - (Number(b.dataset.date) || 0);
        } else if (sortBy === 'title-asc') {
          return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        }
        return 0;
      });

      // Hide all cards
      cards.forEach(card => card.style.display = 'none');
      
      // Show and reorder visible cards
      visibleCards.forEach((card, index) => {
        card.style.display = 'block';
        card.style.order = String(index);
      });
    }

    categoryFilter?.addEventListener('change', filterAndSort);
    sortFilter?.addEventListener('change', filterAndSort);
    searchInput?.addEventListener('input', filterAndSort);
  </script>
</BaseLayout>
