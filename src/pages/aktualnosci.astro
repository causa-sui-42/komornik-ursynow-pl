---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

const allAktualnosci = (await getCollection('aktualnosci'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featuredNews = allAktualnosci.filter(n => n.data.featured);
const regularNews = allAktualnosci.filter(n => !n.data.featured);
const pageTitle = "Aktualno\u015bci - Kancelaria";
const pageDescription = "Najnowsze og\u0142oszenia i informacje z Kancelarii Komorniczej";
const lbl_wazne = "WA\u017bNE";
const lbl_czytaj = "Czytaj wi\u0119cej";
const lbl_czytajStrzalka = "Czytaj wi\u0119cej \u2192";
const lbl_strGl = "Strona g\u0142\u00f3wna";
const lbl_aktualno = "Aktualno\u015bci";
const lbl_noweInfo = "Najnowsze informacje i og\u0142oszenia z kancelarii";
const lbl_wazneOgl = "Wa\u017cne og\u0142oszenia";
const lbl_brakAkt = "Brak aktualno\u015bci";
const lbl_brakAktP = "W tej chwili nie ma opublikowanych aktualno\u015bci.";
const lbl_wszystkAkt = "Wszystkie aktualno\u015bci";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="bg-gray-50 min-h-screen">
    <div class="relative bg-primary-950 text-white overflow-hidden">
      <div class="absolute inset-0 opacity-5">
        <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="aktualnosci-pattern" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
              <path d="M30 5v50M30 5l-10 10M30 5l10 10M15 25l5-10 5 10M35 25l5-10 5 10M15 25h10M35 25h10" stroke="white" stroke-width="0.5" fill="none"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#aktualnosci-pattern)"/>
        </svg>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="flex items-center space-x-2 text-accent-400 text-sm mb-4">
          <a href={base} class="hover:text-accent-300">{lbl_strGl}</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-primary-300">{lbl_aktualno}</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{lbl_aktualno}</h1>
        <p class="text-xl text-primary-300">{lbl_noweInfo}</p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      {featuredNews.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-6 text-gray-900">{lbl_wazneOgl}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {featuredNews.map((news) => (
              <article class="bg-gradient-to-br from-yellow-50 to-yellow-100 border-2 border-yellow-400 rounded-lg p-6 shadow-lg hover:shadow-xl transition">
                <div class="flex items-center mb-4">
                  <svg class="w-6 h-6 text-yellow-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-sm font-semibold text-yellow-800">{lbl_wazne}</span>
                </div>
                <h3 class="text-2xl font-bold mb-2 text-gray-900">
                  <a href={base + "aktualnosci/" + news.slug} class="hover:text-primary-600 transition">
                    {news.data.title}
                  </a>
                </h3>
                <p class="text-gray-700 mb-4">{news.data.description}</p>
                <div class="flex items-center justify-between text-sm">
                  <span class="text-gray-600">
                    {news.data.publishDate.toLocaleDateString('pl-PL')}
                  </span>
                  <a href={base + "aktualnosci/" + news.slug} class="text-primary-600 hover:text-primary-700 font-semibold">
                    {lbl_czytajStrzalka}
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      )}

      {regularNews.length === 0 ? (
        <div class="bg-white rounded-lg shadow-sm p-12 text-center">
          <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
          </svg>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">{lbl_brakAkt}</h3>
          <p class="text-gray-600">{lbl_brakAktP}</p>
        </div>
      ) : (
        <div>
          <h2 class="text-2xl font-bold mb-6 text-gray-900">{lbl_wszystkAkt}</h2>
          <div class="space-y-6">
            {regularNews.map((news) => (
              <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
                <div class="md:flex">
                  {news.data.image && (
                    <div class="md:w-1/3">
                      <img 
                        src={news.data.image} 
                        alt={news.data.title}
                        class="w-full h-full object-cover"
                      />
                    </div>
                  )}
                  <div class={news.data.image ? "md:w-2/3 p-6" : "p-6"}>
                    <div class="flex items-center gap-3 mb-3">
                      <span class="text-sm text-gray-500">
                        {news.data.publishDate.toLocaleDateString('pl-PL')}
                      </span>
                      {news.data.tags && news.data.tags.length > 0 && (
                        <div class="flex gap-2">
                          {news.data.tags.map((tag) => (
                            <span class="px-2 py-1 text-xs font-semibold text-primary-700 bg-primary-100 rounded">
                              {tag}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                    <h3 class="text-2xl font-bold mb-3 text-gray-900">
                      <a href={base + "aktualnosci/" + news.slug} class="hover:text-primary-600 transition">
                        {news.data.title}
                      </a>
                    </h3>
                    <p class="text-gray-600 mb-4 line-clamp-3">{news.data.description}</p>
                    <a href={base + "aktualnosci/" + news.slug} class="inline-flex items-center text-primary-600 hover:text-primary-700 font-semibold">
                      {lbl_czytaj}
                      <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
