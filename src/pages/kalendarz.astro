---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

const wydarzenia = await getCollection('wydarzenia');

// Convert to calendar events format
const calendarEvents = wydarzenia.map(event => ({
  title: event.data.title,
  start: event.data.startDate.toISOString(),
  end: event.data.endDate ? event.data.endDate.toISOString() : undefined,
  allDay: event.data.allDay,
  description: event.data.description,
  location: event.data.location,
  category: event.data.category,
  backgroundColor: 
    event.data.category === 'licytacja' ? '#0ea5e9' :
    event.data.category === 'termin' ? '#8b5cf6' :
    event.data.category === 'wakacje' ? '#ef4444' :
    '#10b981',
}));
const calendarEventsJson = JSON.stringify(calendarEvents).replace(/[\u007F-\uFFFF]/g, function(c) { return '\\u' + c.charCodeAt(0).toString(16).padStart(4, '0'); });
const pageTitle = "Kalendarz termin\u00f3w - Kancelaria Komornicza";
const pageDescription = "Kalendarz wa\u017cnych termin\u00f3w, licytacji i wydarze\u0144 w kancelarii komorniczej";
const lbl_strGl = "Strona g\u0142\u00f3wna";
const lbl_kalTerm = "Kalendarz termin\u00f3w";
const lbl_wazneTerminy = "Wa\u017cne terminy, licytacje i wydarzenia w kancelarii";
const lbl_termSad = "Terminy s\u0105dowe";
const lbl_dniWolne = "Dni wolne";
const lbl_wazne = "Wa\u017cne";
const lbl_arrLic = "\u2192 Wszystkie licytacje";
const lbl_arrAkt = "\u2192 Aktualno\u015bci";
const lbl_arrKon = "\u2192 Kontakt";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="bg-gray-50 min-h-screen">
    <div class="relative bg-primary-950 text-white overflow-hidden">
      <div class="absolute inset-0 opacity-5">
        <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="kalendarz-pattern" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
              <path d="M30 5v50M30 5l-10 10M30 5l10 10M15 25l5-10 5 10M35 25l5-10 5 10M15 25h10M35 25h10" stroke="white" stroke-width="0.5" fill="none"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#kalendarz-pattern)"/>
        </svg>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="flex items-center space-x-2 text-accent-400 text-sm mb-4">
          <a href={base} class="hover:text-accent-300">{lbl_strGl}</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-primary-300">Kalendarz</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{lbl_kalTerm}</h1>
        <p class="text-xl text-primary-300">
          {lbl_wazneTerminy}
        </p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Legend -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-lg shadow-md p-6 sticky top-24">
            <h2 class="text-lg font-bold mb-4 text-gray-900">Legenda</h2>
            <div class="space-y-3">
              <div class="flex items-center">
                <div class="w-4 h-4 rounded bg-blue-500 mr-3"></div>
                <span class="text-sm text-gray-700">Licytacje</span>
              </div>
              <div class="flex items-center">
                <div class="w-4 h-4 rounded bg-purple-500 mr-3"></div>
                <span class="text-sm text-gray-700">{lbl_termSad}</span>
              </div>
              <div class="flex items-center">
                <div class="w-4 h-4 rounded bg-red-500 mr-3"></div>
                <span class="text-sm text-gray-700">{lbl_dniWolne}</span>
              </div>
              <div class="flex items-center">
                <div class="w-4 h-4 rounded bg-green-500 mr-3"></div>
                <span class="text-sm text-gray-700">{lbl_wazne}</span>
              </div>
            </div>

            <div class="mt-6 pt-6 border-t border-gray-200">
              <h3 class="font-semibold mb-3 text-gray-900">Szybkie linki</h3>
              <div class="space-y-2">
                <a href={base + "licytacje"} class="block text-sm text-primary-600 hover:text-primary-700">
                  {lbl_arrLic}
                </a>
                <a href={base + "aktualnosci"} class="block text-sm text-primary-600 hover:text-primary-700">
                  {lbl_arrAkt}
                </a>
                <a href={base + "kontakt"} class="block text-sm text-primary-600 hover:text-primary-700">
                  {lbl_arrKon}
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Calendar -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-lg shadow-md p-6">
            <div id="calendar"></div>
          </div>

          <!-- Event Details Modal -->
          <div id="event-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
            <div class="bg-white rounded-lg max-w-lg w-full p-6">
              <div class="flex justify-between items-start mb-4">
                <h3 id="modal-title" class="text-2xl font-bold text-gray-900"></h3>
                <button id="close-modal" class="text-gray-400 hover:text-gray-600">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                </button>
              </div>
              <div id="modal-content"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css' rel='stylesheet' />
  <script is:inline src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js'></script>
  <script is:inline define:vars={{ calendarEventsJson }}>
    document.addEventListener('DOMContentLoaded', function() {
      var calendarEvents = JSON.parse(calendarEventsJson);
      var calendarEl = document.getElementById('calendar');
      var modal = document.getElementById('event-modal');
      var modalTitle = document.getElementById('modal-title');
      var modalContent = document.getElementById('modal-content');
      var closeModal = document.getElementById('close-modal');

      var calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        locale: 'pl',
        headerToolbar: {
          left: 'prev,next today',
          center: 'title',
          right: 'dayGridMonth,timeGridWeek,listMonth'
        },
        buttonText: {
          today: 'Dziś',
          month: 'Miesiąc',
          week: 'Tydzień',
          list: 'Lista'
        },
        events: calendarEvents,
        eventClick: function(info) {
          modalTitle.textContent = info.event.title;
          
          let content = '';
          if (info.event.extendedProps.description) {
            content += `<p class="text-gray-700 mb-4">${info.event.extendedProps.description}</p>`;
          }
          
          content += '<div class="space-y-2">';
          content += `<p class="text-sm text-gray-600"><strong>Data:</strong> ${info.event.start.toLocaleDateString('pl-PL')}</p>`;
          
          if (info.event.extendedProps.location) {
            content += `<p class="text-sm text-gray-600"><strong>Miejsce:</strong> ${info.event.extendedProps.location}</p>`;
          }
          
          const categoryMap = {
            'licytacja': 'Licytacja',
            'termin': 'Termin sądowy',
            'wakacje': 'Dzień wolny',
            'wazne': 'Ważne wydarzenie'
          };
          content += `<p class="text-sm text-gray-600"><strong>Kategoria:</strong> ${categoryMap[info.event.extendedProps.category] || info.event.extendedProps.category}</p>`;
          content += '</div>';
          
          modalContent.innerHTML = content;
          modal.classList.remove('hidden');
        },
        height: 'auto',
        firstDay: 1 // Monday
      });

      calendar.render();

      closeModal.addEventListener('click', function() {
        modal.classList.add('hidden');
      });

      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          modal.classList.add('hidden');
        }
      });
    });
  </script>
</BaseLayout>
